  "ScriptText": "var DataGrid1 = Matrix.getObject(\"DataGrid1\");\r\nvar DataGrid = Matrix.getObject(\"DataGrid\");\r\nvar btnRUN = Matrix.getObject(\"btnRUN\");\r\nvar VS_EXT_TYPE = Matrix.getObject(\"VS_EXT_TYPE\");\r\n/**\r\n * 파일 내보내기 버튼 클릭 이벤트\r\n * @param sender\r\n * @param args\r\n */\r\nbtnRUN.OnClick = function (sender, args) {\r\n    exportFile();\r\n};\r\n/**\r\n * 엑셀 내보내기 템플릿 생성하기\r\n */\r\nvar exportFile = function () {\r\n    var nowText = Matrix.GetDateTime().ToString(\"yyyy-MM-dd HH:mm:ss\");\r\n    //엑셀 내보내기 모델\r\n    var WORKBOOK = {\r\n        \"FontName\": \"맑은 고딕\",\r\n        \"FontSize\": 11,\r\n        \"WorkSheets\": [\r\n            {\r\n                \"Name\": \"Sheet1\",\r\n                \"DisplayGridlines\": \"false\",\r\n                \"Controls\": [DataGrid.GetExcelExportJSON(\"A2\"), DataGrid1.GetExcelExportJSON(\"A9\")],\r\n                \"Ranges\": []\r\n            }\r\n        ]\r\n    };\r\n    //템플릿 모델 문자열로 변경\r\n    Matrix.AddGlobalParams(\"VS_TEMPLATE\", JSON.stringify(WORKBOOK), 1);\r\n    // 서버 스크립트 실행\r\n    Matrix.RunScript(\"\", \"EXPORT\", function (p) {\r\n        if (p.Success == false) {\r\n            Matrix.Alert(p.Message);\r\n            return;\r\n        }\r\n        // download file\r\n        var fileInfo = p.DataSet;\r\n        var folderName = fileInfo[\"FOLDER_NAME\"];\r\n        var fileName = fileInfo[\"FILE_NAME\"];\r\n        // download.maf 주소\r\n        Matrix.DownloadFile(folderName + \"/\", fileName, Matrix.GetReportInfo().NAME + \"_\" + nowText + \".\" + VS_EXT_TYPE.Value, true);\r\n    });\r\n};\r\n",
  "ServerScriptText": [
    {
      "Name": "EXPORT",
