            " var OnButtonClick  = function(sender, args)",
            " {",
            " \tswitch(args.Id){",
            "\t\tcase \"btnClear\":",
            "\t\t\tOlapGrid.ClearCustomDimensions();\t\t ",
            "\t\t\tOlapGrid.Refresh();",
            "\t\t\tbreak;",
            "\t\tcase \"btnExecute\":",
            "\t\t\tvar nDim = OlapGrid.addCustomDimension(\"창고이름\", tbxGroupName.Text);",
            "\t\t\tnDim.Caption = tbxGroupName.Text;",
            "\t\t\tvar arr= tbxValues.Text.split(\",\");",
            "\t\t\tvar text = '\"' + arr.join(\"\\\",\\\"\") + '\"';",
            "\t\t\tnDim.Formula = ' InList([창고이름], ' + text + ')';",
            "\t\t\tnDim.DataCellStyle = \"BXcc50e79a-71cb-4105-96a5-98a025fdf8bc\";",
            "\t\t\tOlapGrid.Refresh();\t\t",
            "\t\t\tbreak;",
            "\t}",
            " };"
          ],
