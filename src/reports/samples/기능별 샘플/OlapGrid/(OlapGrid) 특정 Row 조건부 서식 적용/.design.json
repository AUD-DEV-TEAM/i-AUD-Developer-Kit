            "ConditionalStyle": "/*  스타일은 반환값이 스타일 목록의 Key 나 Name을 값을 반환해야 합니다.  스타일은 스타일 매니저에서 사전 생성하셔야 합니다.*/ \nSwitch(      \t\t\n  OR (IsRowGrandTotal, IsColGrandTotal, IsRowTotal, IsColTotal)         \t\t\n  \t, \"\"            \n  \t,  AND( getRecordValue([LOCALE]) == \"USA\" , FIELD_KEY == \"Y_VAL\" )             \n  \t,   \"BX1dafda38-cdc2-4c8b-b9a5-e7b7fcb5ce88\"\n  \t,  AND( getRecordValue([LOCALE]) == \"USA\" , FIELD_KEY == \"Q_VAL\" )             \n  \t,\t\"BX86892d07-5943-4038-b765-16c551506f28\"  \n  \t,  AND( getRecordValue([LOCALE]) == \"USA\" , FIELD_KEY == \"H_VAL\" )             \n    ,\t\"BX48B3AB41EE5E44AFAFD2F3A3B6F51431\"\n \t, \t\"BX267DC5B5D58C484B9F9E4AD11CA0ED9A\"\n)  "
