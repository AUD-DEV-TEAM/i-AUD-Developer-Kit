                "Key": "CALC_01",
                "Caption": "계산 필드",
                "Category": 2,
                "DataType": 0,
                "Area": 4,
                "SummaryType": 9,
                "TotalSummaryType": 9,
                "Format": "{0:N0}",
                "Formula": "//----- 지급\ndefine 계산_지급_필터 = {\n    IF([항목구분명] = \"지급\", [원본금액], 0)\n}\ndefine 계산_지급_필터_값 = {\n    ForEach(\"[항목구분명]\", \"[계산_지급_필터]\")\n}\ndefine 계산_지급_값 = {\n  ForAll(GetColumnFields([항목구분명]), \"[계산_지급_필터_값]\", false)\t\n}\n//----- 공제\ndefine 계산_공제_필터 = {\n    IF([항목구분명] = \"공제\", [원본금액], 0)\n}\ndefine 계산_공제_필터_값 = {\n    ForEach(\"[항목구분명]\", \"[계산_공제_필터]\")\n}\ndefine 계산_공제_값 = {\n  ForAll(GetColumnFields([항목구분명]), \"[계산_공제_필터_값]\", false)\t\n}\n\n\nIF(  IsColGrandTotal\n      , SUM( [계산_지급_값] ) - SUM( [계산_공제_값] )\n     , [원본금액] \n )\n \n ",
