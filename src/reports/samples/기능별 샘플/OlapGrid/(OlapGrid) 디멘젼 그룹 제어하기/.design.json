          "Value": [
            "\t//그룹 필드 추가",
            "\tvar targetField = \"창고코드\";",
            "\tvar newField = OlapGrid.addDimensionGroup(targetField ,\"그룹(\" + targetField+ \")\");",
            "\tvar group = newField.DimensionGroupInfo; //디멘젼 그룹 정보",
            "\t",
            "\tvar item = group.AddItem(\"1.ALL\");",
            "\titem.ItemType = 2 ; /*All*/",
            "\t\t\t",
            "\titem = group.AddItem(\"2.SE\");",
            "\titem.ItemType = 0 ; /*Normal*/",
            "\titem.Entries =  ['SE01','SE03','SE04','SE05','SE06','SE09','SE10','SE12','SE20','SE30','SE40','SE50','SE90'];",
            "\t",
            "\titem = group.AddItem(\"3.CS\");",
            "\titem.ItemType = 0 ; /*Normal*/",
            "\titem.Entries = ['CS01','CS10','CS30','CS40','CS99'];",
            "\t",
            "\titem = group.AddItem(\"4.SC\");",
            "\titem.ItemType = 0 ; /*Normal*/",
            "\titem.Entries =  ['SC01','SC02','SC03','SC04'];\t\t",
            "\t",
            "\titem = group.AddItem(\"5.Others\");",
            "\titem.ItemType= 1 ; /*Others*/ \t\t",
            "\t",
            "\tnewField.Area = 1 ; /*Row*/",
            "\tOlapGrid.MoveField(newField.Name ,0, true);",
            "\tOlapGrid.Refresh();"
