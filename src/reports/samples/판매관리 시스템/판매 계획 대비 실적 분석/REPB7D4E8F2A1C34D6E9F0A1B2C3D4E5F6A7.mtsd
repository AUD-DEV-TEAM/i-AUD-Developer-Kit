  "ScriptText": "var viewer;\n/**************************************\n * 문서 로드 된 후 AutoRefresh 수행 전에 발생합니다.\n **************************************/\nvar OnDocumentLoadComplete = function (sender, args) {\n    viewer = Matrix.getObject(\"GRD_PLAN_VS_ACTUAL_View\");\n    viewer.OnComponentClassLoaded = function () {\n        var comp = viewer.getScriptClass(\"\");\n        // 부서 클릭 시 상세 정보 alert\n        comp.addFunction(\"SHOW_DEPT_INFO\", function (row, rowIndex, event) {\n            var msg = \"[ 부서 상세 정보 ]\\n\\n\"\n                + \"부서: \" + row.DEPT_NAME + \"\\n\"\n                + \"담당자: \" + row.EMP_NAME + \"\\n\"\n                + \"연도/월: \" + row.PLAN_YEAR + \"년 \" + row.PLAN_MONTH + \"월\\n\"\n                + \"제품: \" + row.PROD_NAME + \" (\" + row.PROD_CATEGORY + \")\\n\"\n                + \"──────────────────\\n\"\n                + \"목표수량: \" + Number(row.TARGET_QTY).toLocaleString() + \"\\n\"\n                + \"목표금액: \" + Number(row.TARGET_AMT).toLocaleString() + \" 원\\n\"\n                + \"실적금액: \" + Number(row.ACTUAL_AMT).toLocaleString() + \" 원\\n\"\n                + \"달성률: \" + Number(row.ACHV_RATE).toFixed(1) + \"%\";\n            Matrix.Alert(msg);\n        });\n        // 담당자 클릭 시 상세 정보 alert\n        comp.addFunction(\"SHOW_EMP_INFO\", function (row, rowIndex, event) {\n            var diff = Number(row.DIFF_AMT);\n            var status = diff >= 0 ? \"초과 달성\" : \"미달\";\n            var msg = \"[ 담당자 상세 정보 ]\\n\\n\"\n                + \"담당자: \" + row.EMP_NAME + \"\\n\"\n                + \"소속 부서: \" + row.DEPT_NAME + \"\\n\"\n                + \"연도/월: \" + row.PLAN_YEAR + \"년 \" + row.PLAN_MONTH + \"월\\n\"\n                + \"──────────────────\\n\"\n                + \"목표금액: \" + Number(row.TARGET_AMT).toLocaleString() + \" 원\\n\"\n                + \"실적금액: \" + Number(row.ACTUAL_AMT).toLocaleString() + \" 원\\n\"\n                + \"차이: \" + Math.abs(diff).toLocaleString() + \" 원 (\" + status + \")\\n\"\n                + \"달성률: \" + Number(row.ACHV_RATE).toFixed(1) + \"%\";\n            Matrix.Alert(msg);\n        });\n    };\n};\n",
