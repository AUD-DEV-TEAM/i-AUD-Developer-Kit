          },
          "ComponentType": "GridHtmlView",
          "ComponentElement": {
            "DataGridId": "OlapGrid_PlanVsActual_001",
            "HTML": "<div class=\"list-wrap\">\n  <div class=\"table-area\">\n    <table>\n      <thead>\n        <tr>\n          <th style=\"width:60px;\">연도</th>\n          <th style=\"width:40px;\">월</th>\n          <th style=\"width:110px;\">부서</th>\n          <th style=\"width:90px;\">담당자</th>\n          <th style=\"width:110px;\">제품 카테고리</th>\n          <th style=\"width:140px;\">제품</th>\n        </tr>\n        <tr>\n          <th>목표수량</th>\n          <th>목표금액</th>\n          <th>실적수량</th>\n          <th>실적금액</th>\n          <th>차이(금액)</th>\n          <th>달성률(%)</th>\n        </tr>\n      </thead>\n      <tbody AUD-FOR=\"ROWS\">\n        <tr class=\"row1\" AUD-CLASS=\"ACTIVE:active\">\n          <td class=\"center\" AUD-BIND=\"PLAN_YEAR\"></td>\n          <td class=\"center\" AUD-BIND=\"PLAN_MONTH\"></td>\n          <td class=\"center clickable\" AUD-BIND=\"DEPT_NAME\" AUD-ON-CLICK=\"SHOW_DEPT_INFO\"></td>\n          <td class=\"center clickable\" AUD-BIND=\"EMP_NAME\" AUD-ON-CLICK=\"SHOW_EMP_INFO\"></td>\n          <td class=\"center\" AUD-BIND=\"PROD_CATEGORY\"></td>\n          <td AUD-BIND=\"PROD_NAME\"></td>\n        </tr>\n        <tr class=\"row2\" AUD-CLASS=\"ACTIVE:active\">\n          <td class=\"right num\" AUD-BIND=\"TARGET_QTY\"></td>\n          <td class=\"right num\" AUD-BIND=\"TARGET_AMT\"></td>\n          <td class=\"right num\" AUD-BIND=\"ACTUAL_QTY\"></td>\n          <td class=\"right num\" AUD-BIND=\"ACTUAL_AMT\"></td>\n          <td class=\"right num\" AUD-BIND=\"DIFF_AMT\"></td>\n          <td class=\"right num\" AUD-BIND=\"ACHV_RATE\"></td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n  <div class=\"pager\">\n    <button class=\"pg-btn\" AUD-ACTION=\"FIRST\" AUD-DISABLED=\"prevDisabled\">«</button>\n    <button class=\"pg-btn\" AUD-ACTION=\"PREV\" AUD-DISABLED=\"prevDisabled\">‹</button>\n    <button class=\"pg-num\" AUD-FOR=\"PAGES\" AUD-ACTION=\"PAGE\" AUD-CLASS=\"active:active\" AUD-BIND=\"num\"></button>\n    <button class=\"pg-btn\" AUD-ACTION=\"NEXT\" AUD-DISABLED=\"nextDisabled\">›</button>\n    <button class=\"pg-btn\" AUD-ACTION=\"LAST\" AUD-DISABLED=\"nextDisabled\">»</button>\n    <span class=\"pg-info\"><span AUD-BIND=\"CURRENTPAGE\"></span> / <span AUD-BIND=\"LASTPAGE\"></span></span>\n  </div>\n</div>",
            "CSS": ":host { display:block; height:100%; font-family:'Segoe UI',sans-serif; }\n.list-wrap { height:100%; display:flex; flex-direction:column; background:#1e1e2e; }\n.table-area { flex:1; overflow:auto; }\ntable { width:100%; border-collapse:collapse; font-size:13px; }\nthead { position:sticky; top:0; z-index:1; }\nth { background:#2d2d44; color:#cdd6f4; font-weight:600; font-size:12px;\n     padding:8px 12px; text-align:center; border-bottom:1px solid #45475a; }\nthead tr:last-child th { background:#252540; font-size:11px; border-bottom:2px solid #45475a; }\ntd { padding:7px 12px; color:#cdd6f4; }\n.center { text-align:center; }\n.right { text-align:right; }\n.num { font-family:'Consolas','Courier New',monospace; font-size:12px; }\n.row1 td { border-top:1px solid #3b3b55; padding-bottom:3px; }\n.row2 td { background:rgba(255,255,255,.03); padding-top:3px; border-bottom:1px solid #313244; }\ntbody:nth-child(even) .row1 td { background:#262637; }\ntbody:nth-child(even) .row2 td { background:rgba(38,38,55,.85); }\ntbody:hover td { background:#313244 !important; }\n.row1.active td { background:#45475a; color:#fff; font-weight:500; }\n.row1.active td:first-child { border-left:3px solid #89b4fa; }\n.row2.active td { background:#3d3d58; color:#fff; }\n.clickable { cursor:pointer; color:#89b4fa; text-decoration:underline; text-underline-offset:2px; }\n.clickable:hover { color:#b4d0fb; }\n.pager { display:flex; align-items:center; justify-content:center; gap:4px; padding:8px; border-top:1px solid #313244; flex-shrink:0; }\n.pg-btn, .pg-num { border:1px solid #45475a; background:#2d2d44; border-radius:4px; width:28px; height:28px;\n  cursor:pointer; font-size:12px; color:#cdd6f4; display:inline-flex; align-items:center; justify-content:center; }\n.pg-btn:hover:not(:disabled), .pg-num:hover { background:#45475a; }\n.pg-btn:disabled { opacity:.4; cursor:default; }\n.pg-num.active { background:#89b4fa; color:#1e1e2e; border-color:#89b4fa; }\n.pg-info { font-size:11px; color:#6c7086; margin-left:8px; }"
          },
