  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoad = Matrix.getObject(\"btnLoad\");\r\n    var rdoRadial = Matrix.getObject(\"rdoRadial\");\r\n    var rdoOrthogonal = Matrix.getObject(\"rdoOrthogonal\");\r\n    var grdTree = Matrix.getObject(\"grdTree\");\r\n    var ecRadialTree = Matrix.getObject(\"ecRadialTree\");\r\n    lblTitle.Value = \"Radial Tree - Technology Stack\";\r\n    btnLoad.Text = \"Load\";\r\n    btnLoad.OnClick = function () {\r\n        Matrix.doRefresh(\"grdTree\");\r\n    };\r\n    rdoRadial.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecRadialTree.getModel();\r\n            if (model) {\r\n                model.setConfig({ Layout: 'radial' });\r\n                model.Update();\r\n                lblStatus.Value = \"  Radial layout\";\r\n            }\r\n        }\r\n    };\r\n    rdoOrthogonal.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecRadialTree.getModel();\r\n            if (model) {\r\n                model.setConfig({ Layout: 'orthogonal' });\r\n                model.Update();\r\n                lblStatus.Value = \"  Orthogonal layout\";\r\n            }\r\n        }\r\n    };\r\n    ecRadialTree.OnComponentReady = function () {\r\n        var model = ecRadialTree.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setGrid(grdTree);\r\n        model.OnNodeClick = function (args) {\r\n            lblStatus.Value = \"  \" + args.name + (args.parentId ? \" (parent: \" + args.parentId + \")\" : \" (root)\");\r\n        };\r\n    };\r\n};\r\n",
