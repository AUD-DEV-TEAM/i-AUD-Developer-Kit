  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoad = Matrix.getObject(\"btnLoad\");\r\n    var rdoHorizontal = Matrix.getObject(\"rdoHorizontal\");\r\n    var rdoVertical = Matrix.getObject(\"rdoVertical\");\r\n    var grdSankey = Matrix.getObject(\"grdSankey\");\r\n    var ecSankey = Matrix.getObject(\"ecSankey\");\r\n    lblTitle.Value = \"Sankey Chart - Customer Journey Flow\";\r\n    btnLoad.Text = \"Load\";\r\n    btnLoad.OnClick = function () {\r\n        Matrix.doRefresh(\"grdSankey\");\r\n    };\r\n    rdoHorizontal.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecSankey.getModel();\r\n            if (model) {\r\n                model.setConfig({ Orient: 'horizontal' });\r\n                model.Update();\r\n            }\r\n        }\r\n    };\r\n    rdoVertical.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecSankey.getModel();\r\n            if (model) {\r\n                model.setConfig({ Orient: 'vertical' });\r\n                model.Update();\r\n            }\r\n        }\r\n    };\r\n    ecSankey.OnComponentReady = function () {\r\n        var model = ecSankey.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setGrid(grdSankey);\r\n        model.OnNodeClick = function (args) {\r\n            lblStatus.Value = \"  Node: \" + args.name;\r\n        };\r\n        model.OnLinkClick = function (args) {\r\n            lblStatus.Value = \"  \" + args.source + \" → \" + args.target + \" (\" + args.value + \")\";\r\n        };\r\n    };\r\n};\r\n",
