  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoad = Matrix.getObject(\"btnLoad\");\r\n    var btnExpandAll = Matrix.getObject(\"btnExpandAll\");\r\n    var btnCollapseAll = Matrix.getObject(\"btnCollapseAll\");\r\n    var rdoVertical = Matrix.getObject(\"rdoVertical\");\r\n    var rdoHorizontal = Matrix.getObject(\"rdoHorizontal\");\r\n    var grdOrg = Matrix.getObject(\"grdOrg\");\r\n    var ecOrgChart = Matrix.getObject(\"ecOrgChart\");\r\n    lblTitle.Value = \"Organization Chart\";\r\n    btnLoad.Text = \"Load\";\r\n    btnExpandAll.Text = \"Expand All\";\r\n    btnCollapseAll.Text = \"Collapse All\";\r\n    btnLoad.OnClick = function () {\r\n        Matrix.doRefresh(\"grdOrg\");\r\n    };\r\n    btnExpandAll.OnClick = function () {\r\n        var model = ecOrgChart.getModel();\r\n        if (model) {\r\n            model.expandAll();\r\n            lblStatus.Value = \"  All nodes expanded\";\r\n        }\r\n    };\r\n    btnCollapseAll.OnClick = function () {\r\n        var model = ecOrgChart.getModel();\r\n        if (model) {\r\n            model.collapseAll();\r\n            lblStatus.Value = \"  All nodes collapsed\";\r\n        }\r\n    };\r\n    rdoVertical.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecOrgChart.getModel();\r\n            if (model) {\r\n                model.setConfig({ Direction: 'top-to-bottom' });\r\n                model.Update();\r\n            }\r\n        }\r\n    };\r\n    rdoHorizontal.OnValueChange = function (sender, args) {\r\n        if (args.IsChecked) {\r\n            var model = ecOrgChart.getModel();\r\n            if (model) {\r\n                model.setConfig({ Direction: 'left-to-right' });\r\n                model.Update();\r\n            }\r\n        }\r\n    };\r\n    ecOrgChart.OnComponentReady = function () {\r\n        var model = ecOrgChart.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setGrid(grdOrg);\r\n        model.OnNodeClick = function (args) {\r\n            lblStatus.Value = \"  \" + args.name + \" (\" + args.title + \")\";\r\n        };\r\n    };\r\n};\r\n",
