  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoad = Matrix.getObject(\"btnLoad\");\r\n    var grdWordCloud = Matrix.getObject(\"grdWordCloud\");\r\n    var ecWordCloud = Matrix.getObject(\"ecWordCloud\");\r\n    lblTitle.Value = \"Word Cloud - Technology Keyword Trends\";\r\n    btnLoad.Text = \"Load Data\";\r\n    btnLoad.OnClick = function () {\r\n        Matrix.doRefresh(\"grdWordCloud\");\r\n    };\r\n    ecWordCloud.OnComponentReady = function () {\r\n        var model = ecWordCloud.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({\r\n            WordField: 'WORD',\r\n            CountField: 'COUNT',\r\n            Shape: 'circle',\r\n            Title: 'Technology Keyword Trends'\r\n        });\r\n        model.setGrid(grdWordCloud);\r\n        model.OnWordClick = function (args) {\r\n            lblStatus.Value = \"  Clicked: \" + args.word + \" (\" + args.count + \")\";\r\n        };\r\n    };\r\n};\r\n",
