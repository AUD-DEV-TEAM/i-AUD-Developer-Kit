  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoadData = Matrix.getObject(\"btnLoadData\");\r\n    var btnAddEvent = Matrix.getObject(\"btnAddEvent\");\r\n    var btnClear = Matrix.getObject(\"btnClear\");\r\n    var grdTimeline = Matrix.getObject(\"grdTimeline\");\r\n    var ecTimeline = Matrix.getObject(\"ecTimeline\");\r\n    lblTitle.Value = \"Timeline Component - Project Milestones\";\r\n    btnLoadData.Text = \"Load Data\";\r\n    btnAddEvent.Text = \"Add Event\";\r\n    btnClear.Text = \"Clear\";\r\n    var addCounter = 0;\r\n    btnLoadData.OnClick = function () {\r\n        Matrix.doRefresh(\"grdTimeline\");\r\n    };\r\n    btnAddEvent.OnClick = function () {\r\n        addCounter++;\r\n        var today = new Date();\r\n        var mm = today.getMonth() + 1;\r\n        var dd = today.getDate();\r\n        var dateStr = today.getFullYear() + '-'\r\n            + (mm < 10 ? '0' + mm : '' + mm) + '-'\r\n            + (dd < 10 ? '0' + dd : '' + dd);\r\n        var newRow = grdTimeline.AppendRow();\r\n        newRow.SetValue('DATE', dateStr);\r\n        newRow.SetValue('TITLE', 'New Event #' + addCounter);\r\n        newRow.SetValue('DESCRIPTION', 'Added at ' + today.toLocaleTimeString());\r\n        newRow.SetValue('COLOR', '#e91e63');\r\n        newRow.SetValue('ICON', '📌');\r\n        grdTimeline.ReDraw();\r\n        var model = ecTimeline.getModel();\r\n        if (model) {\r\n            model.Update();\r\n        }\r\n    };\r\n    btnClear.OnClick = function () {\r\n        grdTimeline.ClearRows();\r\n        grdTimeline.ReDraw();\r\n        var model = ecTimeline.getModel();\r\n        if (model) {\r\n            model.Update();\r\n        }\r\n        lblStatus.Value = \"  Timeline cleared\";\r\n    };\r\n    ecTimeline.OnComponentReady = function () {\r\n        var model = ecTimeline.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({\r\n            DateField: 'DATE',\r\n            TitleField: 'TITLE',\r\n            DescriptionField: 'DESCRIPTION',\r\n            ColorField: 'COLOR',\r\n            IconField: 'ICON'\r\n        });\r\n        model.setGrid(grdTimeline);\r\n        lblStatus.Value = \"  Timeline ready\";\r\n    };\r\n};\r\n",
