  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var ecHeatmap = Matrix.getObject(\"ecHeatmap\");\r\n    var grdHeatmap = Matrix.getObject(\"grdHeatmap\");\r\n    var btnLoad = Matrix.getObject(\"btnLoad\");\r\n    var btnExport = Matrix.getObject(\"btnExport\");\r\n    var cmbMinColor = Matrix.getObject(\"cmbMinColor\");\r\n    var cmbMaxColor = Matrix.getObject(\"cmbMaxColor\");\r\n    var chkLabel = Matrix.getObject(\"chkLabel\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var minColors = [\"#ffffff\", \"#e3f2fd\", \"#f3e5f5\", \"#fff3e0\", \"#e8f5e9\", \"#fce4ec\"];\r\n    var maxColors = [\"#304ffe\", \"#0d47a1\", \"#4a148c\", \"#e65100\", \"#1b5e20\", \"#b71c1c\"];\r\n    for (var i = 0; i < minColors.length; i++) {\r\n        cmbMinColor.AddItem(minColors[i], minColors[i]);\r\n    }\r\n    for (var i = 0; i < maxColors.length; i++) {\r\n        cmbMaxColor.AddItem(maxColors[i], maxColors[i]);\r\n    }\r\n    cmbMinColor.Value = \"#ffffff\";\r\n    cmbMaxColor.Value = \"#304ffe\";\r\n    btnLoad.OnClick = function () {\r\n        Matrix.doRefresh(\"grdHeatmap\");\r\n    };\r\n    cmbMinColor.OnValueChanged = function (s, e) {\r\n        var model = ecHeatmap.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({ MinColor: cmbMinColor.Value });\r\n        model.Update();\r\n    };\r\n    cmbMaxColor.OnValueChanged = function (s, e) {\r\n        var model = ecHeatmap.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({ MaxColor: cmbMaxColor.Value });\r\n        model.Update();\r\n    };\r\n    chkLabel.OnValueChange = function (s, e) {\r\n        var model = ecHeatmap.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({ ShowLabel: chkLabel.Checked });\r\n        model.Update();\r\n    };\r\n    btnExport.OnClick = function () {\r\n        var model = ecHeatmap.getModel();\r\n        if (model)\r\n            model.exportImage();\r\n    };\r\n    ecHeatmap.OnComponentReady = function () {\r\n        var model = ecHeatmap.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({\r\n            Title: \"Weekly Activity Heatmap\"\r\n        });\r\n        model.setGrid(grdHeatmap);\r\n        model.OnCellClick = function (args) {\r\n            lblStatus.Value = \"  \" + args.row + \" \" + args.col + \" : \" + args.value;\r\n        };\r\n    };\r\n};\r\n",
