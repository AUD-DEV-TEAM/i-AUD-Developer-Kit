  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoadSample = Matrix.getObject(\"btnLoadSample\");\r\n    var btnAddCard = Matrix.getObject(\"btnAddCard\");\r\n    var btnClear = Matrix.getObject(\"btnClear\");\r\n    var btnSave = Matrix.getObject(\"btnSave\");\r\n    var grdKanban = Matrix.getObject(\"grdKanban\");\r\n    var ecKanban = Matrix.getObject(\"ecKanban\");\r\n    lblTitle.Value = \"Kanban Board - Project Task Management\";\r\n    btnLoadSample.Text = \"Load Data\";\r\n    btnAddCard.Text = \"Add Card\";\r\n    btnClear.Text = \"Clear\";\r\n    btnSave.Text = \"Save\";\r\n    var cardCounter = 0;\r\n    var changeCount = 0;\r\n    btnLoadSample.OnClick = function () {\r\n        Matrix.doRefresh(\"grdKanban\");\r\n    };\r\n    btnAddCard.OnClick = function () {\r\n        cardCounter++;\r\n        var newRow = grdKanban.AppendRow();\r\n        newRow.SetValue('TITLE', 'New Task #' + cardCounter);\r\n        newRow.SetValue('STATUS', 'Backlog');\r\n        newRow.SetValue('DESCRIPTION', 'Added at ' + new Date().toLocaleTimeString());\r\n        newRow.SetValue('COLOR', '#ff9800');\r\n        grdKanban.ReDraw();\r\n        var model = ecKanban.getModel();\r\n        if (model) {\r\n            model.Update();\r\n        }\r\n    };\r\n    btnClear.OnClick = function () {\r\n        grdKanban.ClearRows();\r\n        grdKanban.ReDraw();\r\n        var model = ecKanban.getModel();\r\n        if (model) {\r\n            model.Update();\r\n        }\r\n        changeCount = 0;\r\n        lblStatus.Value = \"  All cards cleared\";\r\n    };\r\n    btnSave.OnClick = function () {\r\n        var ds = grdKanban.GetDataSet();\r\n        if (!ds) {\r\n            Matrix.Alert(\"저장할 데이터가 없습니다.\");\r\n            return;\r\n        }\r\n        var dt = ds.GetTable(0);\r\n        var changes = dt.GetChanges('U');\r\n        var modifiedCount = changes.GetRowCount();\r\n        if (modifiedCount === 0) {\r\n            Matrix.Alert(\"변경된 항목이 없습니다.\");\r\n            return;\r\n        }\r\n        var msg = \"변경된 항목 \" + modifiedCount + \"건:\\n\\n\";\r\n        for (var i = 0; i < modifiedCount; i++) {\r\n            msg += \"  - \" + changes.getData(i, 'TITLE') + \" → \" + changes.getData(i, 'STATUS') + \"\\n\";\r\n        }\r\n        Matrix.Alert(msg);\r\n    };\r\n    ecKanban.OnComponentReady = function () {\r\n        var model = ecKanban.getModel();\r\n        if (!model)\r\n            return;\r\n        model.setConfig({\r\n            CardTitleField: 'TITLE',\r\n            CardStatusField: 'STATUS',\r\n            CardDescField: 'DESCRIPTION',\r\n            CardColorField: 'COLOR'\r\n        });\r\n        model.setGrid(grdKanban);\r\n        model.OnCardMoving = function (args) {\r\n            if (args.fromStatus === 'Done' && args.toStatus === 'Backlog') {\r\n                Matrix.Alert(\"완료된 작업은 Backlog로 되돌릴 수 없습니다.\");\r\n                args.cancel = true;\r\n                return;\r\n            }\r\n        };\r\n        model.OnCardMoved = function (args) {\r\n            changeCount++;\r\n            lblStatus.Value = \"  [\" + args.title + \"] \" + args.fromStatus + \" → \" + args.toStatus\r\n                + \"  (변경 \" + changeCount + \"건)\";\r\n        };\r\n    };\r\n};\r\n",
