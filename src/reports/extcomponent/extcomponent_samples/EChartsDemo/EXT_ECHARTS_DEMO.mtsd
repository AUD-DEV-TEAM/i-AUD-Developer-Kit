  "ScriptText": "Matrix.OnDocumentLoadComplete = function (sender, args) {\r\n    var lblTitle = Matrix.getObject(\"lblTitle\");\r\n    var lblStatus = Matrix.getObject(\"lblStatus\");\r\n    var btnLoadData = Matrix.getObject(\"btnLoadData\");\r\n    var btnExport = Matrix.getObject(\"btnExport\");\r\n    var cmbChartType = Matrix.getObject(\"cmbChartType\");\r\n    var cmbTheme = Matrix.getObject(\"cmbTheme\");\r\n    var cmbPalette = Matrix.getObject(\"cmbPalette\");\r\n    var cmbLabel = Matrix.getObject(\"cmbLabel\");\r\n    var cmbLegend = Matrix.getObject(\"cmbLegend\");\r\n    var chkTooltip = Matrix.getObject(\"chkTooltip\");\r\n    var chkToolbox = Matrix.getObject(\"chkToolbox\");\r\n    var chkDataZoom = Matrix.getObject(\"chkDataZoom\");\r\n    var grdSales = Matrix.getObject(\"grdSales\");\r\n    var ecChart = Matrix.getObject(\"ecChart\");\r\n    lblTitle.Value = \"ECharts Component - Sales Dashboard\";\r\n    btnLoadData.Text = \"Load Data\";\r\n    btnExport.Text = \"Export PNG\";\r\n    var chartTypes = ['bar', 'line', 'area', 'pie', 'scatter', 'radar', 'funnel', 'horizontalBar', 'stackedBar', 'stackedLine', 'stackedArea'];\r\n    cmbChartType.ClearDataSet();\r\n    for (var i = 0; i < chartTypes.length; i++) {\r\n        cmbChartType.AddItem(chartTypes[i], chartTypes[i]);\r\n    }\r\n    cmbChartType.Value = 'bar';\r\n    var themes = ['default', 'dark', 'vintage', 'macarons', 'roma', 'shine'];\r\n    cmbTheme.ClearDataSet();\r\n    for (var i = 0; i < themes.length; i++) {\r\n        cmbTheme.AddItem(themes[i], themes[i]);\r\n    }\r\n    cmbTheme.Value = 'default';\r\n    var palettes = ['default', 'pastel', 'vivid', 'monochrome', 'warm', 'cool'];\r\n    cmbPalette.ClearDataSet();\r\n    for (var i = 0; i < palettes.length; i++) {\r\n        cmbPalette.AddItem(palettes[i], palettes[i]);\r\n    }\r\n    cmbPalette.Value = 'vivid';\r\n    var labels = ['none', 'top', 'inside', 'outside', 'left', 'right'];\r\n    cmbLabel.ClearDataSet();\r\n    for (var i = 0; i < labels.length; i++) {\r\n        cmbLabel.AddItem(labels[i], labels[i]);\r\n    }\r\n    cmbLabel.Value = 'none';\r\n    var legendPositions = ['bottom', 'top', 'left', 'right', 'hide'];\r\n    cmbLegend.ClearDataSet();\r\n    for (var i = 0; i < legendPositions.length; i++) {\r\n        cmbLegend.AddItem(legendPositions[i], legendPositions[i]);\r\n    }\r\n    cmbLegend.Value = 'bottom';\r\n    var chartModel = null;\r\n    function applyTitle() {\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setEChartsOption({\r\n            title: { text: '월별 매출 현황', left: 'center', top: 5, textStyle: { fontSize: 14 } }\r\n        });\r\n    }\r\n    btnLoadData.OnClick = function () {\r\n        Matrix.doRefresh(\"grdSales\");\r\n    };\r\n    btnExport.OnClick = function () {\r\n        if (!chartModel)\r\n            return;\r\n        var dataUrl = chartModel.exportImage();\r\n        if (!dataUrl) {\r\n            Matrix.Alert(\"차트 데이터가 없습니다.\");\r\n            return;\r\n        }\r\n        var win = window.open('', '_blank');\r\n        if (win) {\r\n            win.document.write('<img src=\"' + dataUrl + '\" style=\"max-width:100%\"/>');\r\n            win.document.title = 'ECharts Export';\r\n        }\r\n    };\r\n    cmbChartType.OnValueChanged = function (s, e) {\r\n        var val = e.Value;\r\n        if (!val || !chartModel)\r\n            return;\r\n        chartModel.setChartType(val);\r\n        applyTitle();\r\n        lblStatus.Value = \"  Chart type: \" + val;\r\n    };\r\n    cmbTheme.OnValueChanged = function (s, e) {\r\n        var val = e.Value;\r\n        if (!val || !chartModel)\r\n            return;\r\n        var inst = chartModel.getEChartsInstance();\r\n        if (!inst)\r\n            return;\r\n        var container = inst.getDom();\r\n        var width = container.clientWidth;\r\n        var height = container.clientHeight;\r\n        inst.dispose();\r\n        var ec = chartModel.getECharts();\r\n        var newInst = ec.init(container, val === 'default' ? null : val);\r\n        newInst.resize({ width: width, height: height });\r\n        chartModel.chart = newInst;\r\n        chartModel.Update();\r\n        applyTitle();\r\n        lblStatus.Value = \"  Theme: \" + val;\r\n    };\r\n    cmbPalette.OnValueChanged = function (s, e) {\r\n        var val = e.Value;\r\n        if (!val || !chartModel)\r\n            return;\r\n        chartModel.setConfig({ ColorPalette: val });\r\n        chartModel.Update();\r\n        applyTitle();\r\n        lblStatus.Value = \"  Palette: \" + val;\r\n    };\r\n    cmbLabel.OnValueChanged = function (s, e) {\r\n        var val = e.Value;\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setConfig({ LabelPosition: val || 'none' });\r\n        chartModel.Update();\r\n        applyTitle();\r\n        lblStatus.Value = \"  Label: \" + (val || 'none');\r\n    };\r\n    cmbLegend.OnValueChanged = function (s, e) {\r\n        var val = e.Value;\r\n        if (!chartModel)\r\n            return;\r\n        if (val === 'hide') {\r\n            chartModel.setConfig({ ShowLegend: false });\r\n        }\r\n        else {\r\n            chartModel.setConfig({ ShowLegend: true, LegendPosition: val });\r\n        }\r\n        chartModel.Update();\r\n        applyTitle();\r\n        lblStatus.Value = \"  Legend: \" + val;\r\n    };\r\n    chkTooltip.OnValueChange = function () {\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setConfig({ ShowTooltip: chkTooltip.IsChecked });\r\n        chartModel.Update();\r\n        applyTitle();\r\n    };\r\n    chkToolbox.OnValueChange = function () {\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setConfig({ ShowToolbox: chkToolbox.IsChecked });\r\n        chartModel.Update();\r\n        applyTitle();\r\n    };\r\n    chkDataZoom.OnValueChange = function () {\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setConfig({ EnableDataZoom: chkDataZoom.IsChecked });\r\n        chartModel.Update();\r\n        applyTitle();\r\n    };\r\n    ecChart.OnComponentReady = function () {\r\n        chartModel = ecChart.getModel();\r\n        if (!chartModel)\r\n            return;\r\n        chartModel.setGrid(grdSales);\r\n        applyTitle();\r\n        lblStatus.Value = \"  Chart ready | Change options above\";\r\n    };\r\n};\r\n",
